<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/purple_background_color"
    android:gravity="center">

    <LinearLayout
        android:id="@+id/top_navigation_title_layout"
        style="@style/NavigationLinearLayout"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/navigation_back_button"
            style="@style/SmallButton"
            android:visibility="visible"
            app:cornerRadius="20dp"

            app:icon="@drawable/ic_arrow_left"
            app:iconSize="30dp"
            app:iconGravity="top"
            />

        <TextView
            android:id="@+id/navigation_title_view"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/default_hello_world_text"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:padding="10dp"
            android:layout_weight="5"/>

    </LinearLayout>


    <LinearLayout
        android:id="@+id/top_navigation_debugTools_layout"
        android:layout_below="@+id/top_navigation_title_layout"
        style="@style/NavigationLinearLayout"
        android:gravity="center"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            style="@style/DebugToolButton"
            android:id="@+id/update_nextDeadline_button"
            app:icon="@drawable/ic_update"
            app:iconSize="30dp"
            app:iconGravity="top"/>

        <com.google.android.material.button.MaterialButton
            style="@style/DebugToolButton"
            android:id="@+id/reset_userStatus_button"
            app:icon="@drawable/ic_delete"
            app:iconSize="30dp"
            app:iconGravity="top"/>

        <CheckBox
            android:id="@+id/autoCheck_button"
            style="@style/SpreadLinearLayoutItem"/>

    </LinearLayout>

</RelativeLayout>