<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="75dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        >

        <RelativeLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/habit_title_card_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/header2_text"
                android:layout_margin="0dp"
                android:text="@string/default_hello_world_text"/>
            <TextView
                android:id="@+id/habit_desc_card_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/collapsed_description"
                android:layout_below="@+id/habit_title_card_view"
                android:text="@string/default_hello_world_text"/>
        </RelativeLayout>

        <Button
            android:id="@+id/habit_card_change_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/white"
            android:textColor="@color/black"
            android:text="@string/habit_change_btn_text"
            style="@style/UncheckedHabitButton"
        />
        <!--android:drawable="@drawable/pencil_svgrepo_com"-->
        
        <Button
            android:id="@+id/habit_card_check_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/SmallButton"
            android:text="@string/habit_check_btn_text"/>
        
        <TextView
            android:id="@+id/habit_streak_textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_number_text"
            android:layout_margin="10dp"
            />

        <TextView
            android:id="@+id/habit_penalty_textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_number_text"
            />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>