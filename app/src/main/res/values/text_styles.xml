<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="standard_text">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">#000000</item>
    </style>

    <style name="StandardTextView" parent="standard_text">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="title_text" parent="StandardTextView">
        <item name="android:textSize">30sp</item>
        <item name="android:layout_margin">30dp</item>
    </style>

    <style name="header1_text" parent="StandardTextView">
        <item name="android:textSize">20sp</item>
    </style>

    <style name="header2_text" parent="StandardTextView">
        <item name="android:textSize">15sp</item>
    </style>

    <style name="collapsed_description" parent="StandardTextView">
        <item name="android:alpha">0.5</item>
    </style>

    <style name="error_text">
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textSize">20sp</item>
        <item name="android:text">@string/default_hello_world_text</item>
    </style>

    <style name="ErrorMessage" parent="error_text">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/msg_error_bg</item>
        <item name="android:padding">20dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:gravity">start</item>
    </style>

    <style name="InfoMessage" parent="error_text">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/msg_info_bg</item>
        <item name="android:padding">20dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:gravity">start</item>
    </style>
</resources>