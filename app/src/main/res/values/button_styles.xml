<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="register_page_btn" parent="Widget.AppCompat.Button.Colored">
        <item name="colorButtonNormal">#FFFFFF</item>
        <item name="android:textColor">#000000</item>
    </style>

    <style name="SmallButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">48dp</item>
        <item name="cornerRadius">8dp</item>
    </style>


    <style name="CharacterButton">
        <item name="android:layout_height">@dimen/character_button_size</item>
        <item name="android:layout_width">@dimen/character_button_size</item>
        <item name="android:layout_marginHorizontal">10dp</item>
        <item name="android:enabled">false</item>
    </style>

    <style name="EquipmentButton">
        <item name="android:layout_height">@dimen/equipment_button_size</item>
        <item name="android:layout_width">@dimen/equipment_button_size</item>
        <item name="android:layout_marginHorizontal">10dp</item>
    </style>

    <dimen name="equipment_icon_size">100dp</dimen>
    <dimen name="equipment_button_size">125dp</dimen>
    <dimen name="character_icon_size">125dp</dimen>
    <dimen name="character_button_size">150dp</dimen>


    <style name="UncheckedHabitButton" parent="SmallButton">
        <item name="backgroundTint">@color/habit_unchecked_btn_color</item>
        <item name="android:textColor">@color/habit_unchecked_btn_text_color</item>
    </style>

    <style name="CheckedHabitButton" parent="UncheckedHabitButton">
        <item name="backgroundTint">@color/habit_checked_btn_color</item>
        <item name="android:textColor">@color/habit_checked_btn_text_color</item>
    </style>

    <style name="NavButton" parent="Widget.MaterialComponents.Button.Icon">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">58dp</item>
        <item name="android:paddingStart">9dp</item>
        <item name="android:paddingEnd">9dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:paddingTop">12dp</item>
    </style>

    <style name="DebugToolButton" parent="SpreadLinearLayoutItem">
        <item name="android:layout_height">58dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingHorizontal">0dp</item>
    </style>


    <style name="TimeOutlineButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>